{
  "ConnectionStrings": {
    "DefaultConnection": "Server=mssql;Database=ShopApp;User Id=shopapp_user;Password=${SHOPAPP_DB_PASSWORD};TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "ShopApp",
    "Audience": "ShopAppUsers",
    "ExpiryHours": "8"
  },
  "Gemini": {
    "ApiKey": "${GEMINI_API_KEY}"
  },
  "App": {
    "BaseUrl": "http://localhost:8080"
  },
  "Przelewy24": {
    "MerchantId": 0,
    "PosId": 0,
    "CrcKey": "${P24_CRC_KEY}",
    "ReportKey": "${P24_REPORT_KEY}",
    "Sandbox": true
  },
  "FileStorage": {
    "BasePath": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
