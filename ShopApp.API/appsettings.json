{
  "ConnectionStrings": {
    "DefaultConnection": "Server=mssql;Database=ShopApp;User Id=sa;Password=${MSSQL_SA_PASSWORD};TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "${JWT_SECRET_KEY}",
    "Issuer": "ShopApp",
    "Audience": "ShopAppUsers",
    "ExpiryHours": "8"
  },
  "Gemini": {
    "ApiKey": "${GEMINI_API_KEY}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
